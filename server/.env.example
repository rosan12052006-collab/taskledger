PORT=5000

DB_MODE=

MONGO_URI_LOCAL=mongodb://localhost:27017/task-ledger
MONGO_URI_ATLAS=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/task-ledger

JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# ---- Email reminders via Gmail (optional) ----
GMAIL_USER=
GMAIL_APP_PASSWORD=
REMINDER_CRON=0 8 * * *
